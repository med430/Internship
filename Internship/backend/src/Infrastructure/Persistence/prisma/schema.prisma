generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//
// ENUMS
//

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum Role {
  STUDENT
  RECRUITER
  ADMIN
}

enum OfferType {
  INTERNSHIP
  PFE
  RESEARCH
  PHD
}

//
// USER
//

model User {
  id           String @id @default(uuid())
  email        String @unique
  name         String
  lastname     String
  username     String @unique
  passwordHash String
  role         Role

  studentProfile   StudentProfile?
  recruiterProfile RecruiterProfile?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  offers    Offer[]   @relation("UserOffers")
}

//
// PROFILES
//

model StudentProfile {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  bio String?

  cvs             CV[]
  skills          SkillAssignment[]
  applications    Application[]
  recommendations Recommendation[]
  interviews      Interview[]

  educations     Education[]
  certifications Certification[]

  experiences Experience[] // 🔥 AJOUT
  projects    Project[] // 🔥 AJOUT
}

model RecruiterProfile {
  id String @id @default(uuid())

  userId          String           @unique
  user            User             @relation(fields: [userId], references: [id])
  company         String
  offers          Offer[]
  recommendations Recommendation[]
}

//
// RECOMMENDATION
//

model Recommendation {
  id String @id @default(uuid())

  recruiterId String
  recruiter   RecruiterProfile @relation(fields: [recruiterId], references: [id]) // 🔥 FIX

  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id])

  description String

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

//
// PROJECT
//

model Project {
  id String @id @default(uuid())

  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])

  title        String
  description  String
  technologies String[]
}

//
// CV
//

model CV {
  id String @id @default(uuid())

  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id])

  fileUrl    String
  parsedData Json? // 🔥 pour OCR / AI

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

//
// EXPERIENCE
//

model Experience {
  id String @id @default(uuid())

  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])

  company String
  role    String

  startDate DateTime
  endDate   DateTime?

  description String?
}

//
// OFFER
//
model Offer {
  id String @id @default(uuid())

  recruiterProfileId String
  recruiterProfile   RecruiterProfile @relation(fields: [recruiterProfileId], references: [id])

  title       String
  description String

  company  String
  location String
  domain   String

  startDate DateTime
  endDate   DateTime

  type OfferType

  skillRequirements SkillRequirement[]
  applications      Application[]

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?
  interviews       Interview[]
  user             User?             @relation("UserOffers", fields: [userId], references: [id])
  userId           String?
  skillAssignments SkillAssignment[]
}

//
// APPLICATION
//
model Application {
  id String @id @default(uuid())

  studentId String
  offerId   String

  status     ApplicationStatus
  cvUrl      String
  matchScore Float

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  offer   Offer          @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([studentId, offerId])
  @@index([studentId])
  @@index([offerId])
}

//
// SKILLS
//

model Skill {
  id   Int    @id @default(autoincrement())
  name String @unique

  assignments       SkillAssignment[]
  skillRequirements SkillRequirement[]
}

model SkillAssignment {
  id String @id @default(uuid())

  skillId Int
  skill   Skill @relation(fields: [skillId], references: [id])

  // 🔥 OPTIONNEL POUR OFFER
  offerId String?
  offer   Offer?  @relation(fields: [offerId], references: [id])

  // 🔥 OPTIONNEL POUR STUDENT
  studentProfileId String?
  studentProfile   StudentProfile? @relation(fields: [studentProfileId], references: [id])

  level SkillLevel
}

///
/// SKILLREQUIREMENT
///
model SkillRequirement {
  id String @id @default(uuid())

  skillId Int
  skill   Skill @relation(fields: [skillId], references: [id])

  level   SkillLevel
  offer   Offer?     @relation(fields: [offerId], references: [id])
  offerId String?
}

//
// INTERVIEW
//
model Interview {
  id String @id @default(uuid())

  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id])

  offerId String
  offer   Offer  @relation(fields: [offerId], references: [id])

  score    Float
  feedback String
  summary  String?
}

model Education {
  id String @id @default(uuid())

  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])

  school String
  degree String
  field  String

  startDate DateTime
  endDate   DateTime?

  description String?
}

model Certification {
  id String @id @default(uuid())

  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])

  name         String
  organization String

  issueDate      DateTime
  expirationDate DateTime?

  credentialId  String?
  credentialUrl String?
}
