# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_JWT_SECRET=   # Settings → API → JWT Secret

# API URLs
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_API_URL_WS=ws://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:5173
NEXT_PUBLIC_SUPABASE_REDIRECT_URL=http://localhost:5173/auth/callback
NEXT_PUBLIC_SUPABASE_PASSWORD_RESET_REDIRECT_URL=http://localhost:5173/auth/callback?next=/reset-password

# AI APIs
GROQ_API_KEY=
GROQ_WHISPER_MODEL=whisper-large-v3
GROQ_LLM_MODEL=llama-3.3-70b-versatile

ELEVEN_LABS_API_KEY=
ELEVEN_LABS_TTS_MODEL=eleven_multilingual_v2
ELEVEN_LABS_VOICE_EMPATHIC=
ELEVEN_LABS_VOICE_TECHNICAL=
ELEVEN_LABS_VOICE_DIRECT=

# PostgreSQL (NeonDB)
DB_URL=

# JWT
JWT_SECRET=dev-secret-change-me
JWT_EXPIRATION_TIME=3600

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ML Service
ML_SERVICE_URL=http://localhost:8000
ML_MOCK=true
ML_INTERNAL_TOKEN=dev-token

# MongoDB (chat) — use Atlas standard string or local Docker
# Docker local: mongodb://localhost:27017/stagio
# Atlas standard: mongodb://user:pass@ac-xxx-shard-00-00.er3czgo.mongodb.net:27017,.../?ssl=true&replicaSet=atlas-xxx-shard-0&authSource=admin
CHAT_DB_URL=mongodb://localhost:27017/stagio
