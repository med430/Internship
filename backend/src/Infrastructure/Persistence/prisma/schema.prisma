generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum ApplicationStatus {
  SUBMITTED
  IN_REVIEW
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum Role {
  STUDENT
  RECRUITER
  ADMIN
}

enum OfferType {
  INTERNSHIP
  PFE
  RESEARCH
  PHD
}

enum WorkMode {
  REMOTE
  ONSITE
  HYBRID
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum InterviewStatus {
  IN_PROGRESS
  COMPLETED
}

enum RecruiterMode {
  EMPATHIC
  TECHNICAL
  DIRECT
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────

model User {
  id           String @id @default(uuid())
  email        String @unique
  name         String
  lastname     String
  username     String @unique
  passwordHash String
  role         Role

  phone     String?
  avatarUrl String?

  studentProfile   StudentProfile?
  recruiterProfile RecruiterProfile?
  interviews       Interview[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

// ─────────────────────────────────────────
// PROFILES
// ─────────────────────────────────────────

model StudentProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  bio       String?
  birthDate DateTime?
  gender    Gender?
  address   String?
  city      String?

  skills         SkillAssignment[]
  experiences    Experience[]
  projects       Project[]
  educations     Education[]
  certifications Certification[]
  cvs            CV[]
  applications   Application[]
}

model RecruiterProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  company            String
  companyDescription String?
  website            String?

  offers Offer[]
}

// ─────────────────────────────────────────
// PROJECT
// ─────────────────────────────────────────

model Project {
  id               String         @id @default(uuid())
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])

  title        String
  description  String
  technologies String[]
  githubUrl    String?
  demoUrl      String?
}

// ─────────────────────────────────────────
// CV
// ─────────────────────────────────────────
model CV {
  id           String         @id @default(uuid())
  studentId    String
  student      StudentProfile @relation(fields: [studentId], references: [id])
  fileUrl      String
  applications Application[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model CoverLetter {
  id           String        @id @default(uuid())
  studentId    String
  fileUrl      String
  applications Application[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

// ─────────────────────────────────────────
// EXPERIENCE
// ─────────────────────────────────────────

model Experience {
  id               String         @id @default(uuid())
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])

  company     String
  role        String
  startDate   DateTime
  endDate     DateTime?
  description String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

// ─────────────────────────────────────────
// EDUCATION
// ─────────────────────────────────────────

model Education {
  id               String         @id @default(uuid())
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])

  school      String
  degree      String
  field       String
  startDate   DateTime
  endDate     DateTime?
  description String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

// ─────────────────────────────────────────
// CERTIFICATION
// ─────────────────────────────────────────

model Certification {
  id               String         @id @default(uuid())
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])

  name           String
  organization   String
  issueDate      DateTime
  expirationDate DateTime?
  credentialId   String?
  credentialUrl  String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

// ─────────────────────────────────────────
// OFFER
// ─────────────────────────────────────────

model Offer {
  id                 String           @id @default(uuid())
  recruiterProfileId String
  recruiterProfile   RecruiterProfile @relation(fields: [recruiterProfileId], references: [id])

  title       String
  description String
  company     String
  location    String
  domain      String

  isPaid    Boolean
  workMode  WorkMode
  startDate DateTime
  endDate   DateTime
  type      OfferType

  skillRequirements SkillRequirement[]
  applications      Application[]
  interviews        Interview[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

// ─────────────────────────────────────────
// SKILL
// ─────────────────────────────────────────

model Skill {
  id   Int    @id @default(autoincrement())
  name String @unique

  assignments       SkillAssignment[]
  skillRequirements SkillRequirement[]
}

model SkillAssignment {
  id               String         @id @default(uuid())
  skillId          Int
  skill            Skill          @relation(fields: [skillId], references: [id])
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])
  level            SkillLevel
}

model SkillRequirement {
  id      String     @id @default(uuid())
  skillId Int
  skill   Skill      @relation(fields: [skillId], references: [id])
  offerId String
  offer   Offer      @relation(fields: [offerId], references: [id])
  level   SkillLevel
}

// ─────────────────────────────────────────
// APPLICATION
// ─────────────────────────────────────────
model Application {
  id        String @id @default(uuid())
  studentId String
  offerId   String

  cvId          String
  coverLetterId String?

  status     ApplicationStatus
  matchScore Float             @default(0)

  student     StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  offer       Offer          @relation(fields: [offerId], references: [id], onDelete: Cascade)
  cv          CV             @relation(fields: [cvId], references: [id])
  coverLetter CoverLetter?   @relation(fields: [coverLetterId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([studentId, offerId])
  @@index([studentId])
  @@index([offerId])
}

// ─────────────────────────────────────────
// INTERVIEW
// ─────────────────────────────────────────
model Interview {
  id             String          @id @default(uuid())
  studentId      String
  offerId        String?

  company        String?
  jobTitle       String?
  jobDescription String?

  recruiterMode RecruiterMode   @default(EMPATHIC)
  status        InterviewStatus @default(IN_PROGRESS)

  score    Float  @default(0)
  feedback String @default("")
  summary  String?

  data Json?

  student User  @relation(fields: [studentId], references: [id])
  offer   Offer? @relation(fields: [offerId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([studentId])
  @@index([offerId])
}
