generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum ApplicationStatus {
  SUBMITTED
  IN_REVIEW
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum Role {
  STUDENT
  RECRUITER
  ADMIN
}

enum OfferType {
  INTERNSHIP
  PFE
  RESEARCH
  PHD
  ALTERNANCE
}

enum WorkMode {
  REMOTE
  ONSITE
  HYBRID
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum InterviewStatus {
  IN_PROGRESS
  COMPLETED
}

enum RecruiterMode {
  EMPATHIC
  TECHNICAL
  DIRECT
}

enum InterviewSlotStatus {
  PROPOSED
  ACCEPTED
  DECLINED
  CONFIRMED
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────

model User {
  id           String @id @default(uuid())
  email        String @unique
  name         String
  lastname     String
  username     String @unique
  passwordHash String
  role         Role

  phone     String?
  avatarUrl String?

  studentProfile   StudentProfile?
  recruiterProfile RecruiterProfile?
  interviews       Interview[]

  // Behavioral back-relations (recommendation system)
  offerViews              OfferView[]
  offerBookmarks          OfferBookmark[]
  offerImpressions        OfferImpression[]
  searchQueries           SearchQuery[]
  profileViewsAsRecruiter ProfileView[]        @relation("RecruiterViews")
  recommendationScores    RecommendationScore[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

// ─────────────────────────────────────────
// PROFILES
// ─────────────────────────────────────────

model StudentProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  bio       String?
  birthDate DateTime?
  gender    Gender?
  address   String?
  city      String?
  domains   String[]

  // Recommendation preferences (additive — nullable / default / array)
  preferredDomains    String[]
  preferredCities     String[]
  preferredWorkMode   WorkMode?
  availableFrom       DateTime?
  availableTo         DateTime?
  paidOnly            Boolean      @default(false)
  preferredOfferTypes OfferType[]
  languages           String[]
  maxCommuteCities    String[]

  // Academic context (structured)
  schoolId       Int?
  school         School? @relation(fields: [schoolId], references: [id])
  currentYear    Int?
  currentProgram String?

  skills         SkillAssignment[]
  experiences    Experience[]
  projects       Project[]
  educations     Education[]
  certifications Certification[]
  cvs            CV[]
  applications   Application[]

  // Behavioral back-relations (recommendation system)
  profileViewsReceived ProfileView[]
}

model RecruiterProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  company            String
  companyDescription String?
  website            String?

  offers Offer[]
}

// ─────────────────────────────────────────
// PROJECT
// ─────────────────────────────────────────

model Project {
  id               String         @id @default(uuid())
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])

  title        String
  description  String
  technologies String[]
  githubUrl    String?
  demoUrl      String?
}

// ─────────────────────────────────────────
// CV
// ─────────────────────────────────────────
model CV {
  id           String         @id @default(uuid())
  studentId    String
  student      StudentProfile @relation(fields: [studentId], references: [id])
  fileUrl      String
  applications Application[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model CoverLetter {
  id           String        @id @default(uuid())
  studentId    String
  fileUrl      String
  applications Application[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

// ─────────────────────────────────────────
// EXPERIENCE
// ─────────────────────────────────────────

model Experience {
  id               String         @id @default(uuid())
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])

  company     String
  role        String
  startDate   DateTime
  endDate     DateTime?
  description String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

// ─────────────────────────────────────────
// EDUCATION
// ─────────────────────────────────────────

model Education {
  id               String         @id @default(uuid())
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])

  school      String
  degree      String
  field       String
  startDate   DateTime
  endDate     DateTime?
  description String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

// ─────────────────────────────────────────
// CERTIFICATION
// ─────────────────────────────────────────

model Certification {
  id               String         @id @default(uuid())
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])

  name           String
  organization   String
  issueDate      DateTime
  expirationDate DateTime?
  credentialId   String?
  credentialUrl  String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

// ─────────────────────────────────────────
// OFFER
// ─────────────────────────────────────────

model Offer {
  id                 String           @id @default(uuid())
  recruiterProfileId String
  recruiterProfile   RecruiterProfile @relation(fields: [recruiterProfileId], references: [id])

  title       String
  description String
  company     String
  location    String
  domain      String

  isPaid    Boolean
  workMode  WorkMode
  startDate DateTime
  endDate   DateTime
  type      OfferType

  // Recommendation-critical (additive — nullable / default / array)
  applicationDeadline DateTime?
  positionsCount      Int       @default(1)
  stipendMin          Float?
  stipendMax          Float?
  languagesRequired   String[]

  skillRequirements SkillRequirement[]
  applications      Application[]
  interviews        Interview[]

  // Behavioral back-relations (recommendation system)
  views                OfferView[]
  bookmarks            OfferBookmark[]
  impressions          OfferImpression[]
  recommendationScores RecommendationScore[]
  profileViews         ProfileView[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

// ─────────────────────────────────────────
// SKILL
// ─────────────────────────────────────────

model Skill {
  id   Int    @id @default(autoincrement())
  name String @unique

  assignments       SkillAssignment[]
  skillRequirements SkillRequirement[]
}

model SkillAssignment {
  id               String         @id @default(uuid())
  skillId          Int
  skill            Skill          @relation(fields: [skillId], references: [id])
  studentProfileId String
  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])
  level            SkillLevel
}

model SkillRequirement {
  id        String     @id @default(uuid())
  skillId   Int
  skill     Skill      @relation(fields: [skillId], references: [id])
  offerId   String
  offer     Offer      @relation(fields: [offerId], references: [id])
  level     SkillLevel
  mandatory Boolean    @default(true)
}

// ─────────────────────────────────────────
// APPLICATION
// ─────────────────────────────────────────
model Application {
  id        String @id @default(uuid())
  studentId String
  offerId   String

  cvId          String
  coverLetterId String?

  status     ApplicationStatus
  matchScore Float             @default(0)

  student     StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  offer       Offer          @relation(fields: [offerId], references: [id], onDelete: Cascade)
  cv          CV             @relation(fields: [cvId], references: [id])
  coverLetter CoverLetter?   @relation(fields: [coverLetterId], references: [id])

  interviewSlots InterviewSlot[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([studentId, offerId])
  @@index([studentId])
  @@index([offerId])
}

// ─────────────────────────────────────────
// INTERVIEW SLOT (scheduling)
// ─────────────────────────────────────────
model InterviewSlot {
  id               String              @id @default(uuid())
  applicationId    String
  proposedByUserId String
  startAt          DateTime
  endAt            DateTime
  status           InterviewSlotStatus @default(PROPOSED)
  notes            String?
  parentSlotId     String?

  application  Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  parentSlot   InterviewSlot? @relation("rescheduled", fields: [parentSlotId], references: [id])
  counterSlots InterviewSlot[] @relation("rescheduled")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([applicationId])
  @@index([proposedByUserId])
}

// ─────────────────────────────────────────
// INTERVIEW
// ─────────────────────────────────────────
model Interview {
  id             String          @id @default(uuid())
  studentId      String
  offerId        String?

  company        String?
  jobTitle       String?
  jobDescription String?

  recruiterMode RecruiterMode   @default(EMPATHIC)
  status        InterviewStatus @default(IN_PROGRESS)

  score    Float  @default(0)
  feedback String @default("")
  summary  String?

  data Json?

  student User  @relation(fields: [studentId], references: [id])
  offer   Offer? @relation(fields: [offerId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([studentId])
  @@index([offerId])
}

// ─────────────────────────────────────────
// ONBOARD PUBLIC SESSION DATA
// ─────────────────────────────────────────

model PublicSessionProfile {
  id                  String   @id @default(uuid())
  sessionKey          String   @unique
  name                String   @default("")
  email               String?
  location            String?
  birthDate           DateTime?
  targetedRole        String?
  organization        String?
  skills              String[]
  education           String[]
  experiences         String[]
  achievements        String[]
  githubUrl           String?
  linkedinUrl         String?
  twitterUrl          String?
  avatarUrl           String?
  profileCompleted    Boolean  @default(false)
  isDeactivated       Boolean  @default(false)
  deactivatedAt       DateTime?
  subscription        String   @default("Starter")
  subscriptionEndDate DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model PublicCvQuestionSession {
  id            String   @id @default(uuid())
  sessionKey    String
  status        String   @default("OPEN")
  questionsJson Json
  metadata      Json
  cvText        String   @db.Text
  jobsText      String   @db.Text
  expiresAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([sessionKey])
  @@index([createdAt])
}

model PublicCv {
  id               String   @id @default(uuid())
  sessionKey       String
  questionSessionId String?
  pdfUrl           String
  originalScore    Float
  finalScore       Float
  jobTitle         String
  jobsSummary      String   @db.Text
  reviewImprovements String[]
  anonymizedCvText String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([sessionKey])
  @@index([createdAt])
}

model PublicCoverLetter {
  id         String   @id @default(uuid())
  sessionKey String
  fileUrl    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([sessionKey])
  @@index([createdAt])
}

model PublicCareerGuide {
  id                    String   @id @default(uuid())
  sessionKey            String
  currentStrengths      String[]
  readinessScore        Int
  skillsToLearn         String[]
  projectsToWorkOn      String[]
  softSkillsToDevelop   String[]
  careerRoadmap         String[]
  domain                String
  currentJob            String
  targetJob             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([sessionKey])
  @@index([createdAt])
}

model PublicPortfolioGeneration {
  id         String   @id @default(uuid())
  sessionKey String
  wireframe  String
  theme      String
  html       String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([sessionKey])
  @@index([createdAt])
}

// ─────────────────────────────────────────
// RECOMMENDATION SYSTEM
// ─────────────────────────────────────────

model School {
  id       Int     @id @default(autoincrement())
  name     String  @unique
  fullName String
  city     String
  type     String?
  website  String?

  studentProfiles StudentProfile[]
}

model OfferView {
  id         String   @id @default(uuid())
  studentId  String
  offerId    String
  viewedAt   DateTime @default(now())
  durationMs Int?
  source     String?

  student User  @relation(fields: [studentId], references: [id])
  offer   Offer @relation(fields: [offerId], references: [id])

  @@index([studentId])
  @@index([offerId])
  @@index([viewedAt])
}

model OfferBookmark {
  id        String    @id @default(uuid())
  studentId String
  offerId   String
  createdAt DateTime  @default(now())
  removedAt DateTime?

  student User  @relation(fields: [studentId], references: [id])
  offer   Offer @relation(fields: [offerId], references: [id])

  @@unique([studentId, offerId])
  @@index([studentId])
}

model OfferImpression {
  id       String   @id @default(uuid())
  studentId String
  offerId  String
  shownAt  DateTime @default(now())
  position Int?

  student User  @relation(fields: [studentId], references: [id])
  offer   Offer @relation(fields: [offerId], references: [id])

  @@index([studentId, shownAt])
  @@index([offerId])
}

model ProfileView {
  id               String   @id @default(uuid())
  recruiterUserId  String
  studentProfileId String
  offerId          String?
  viewedAt         DateTime @default(now())

  recruiter      User           @relation("RecruiterViews", fields: [recruiterUserId], references: [id])
  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id])
  offer          Offer?         @relation(fields: [offerId], references: [id])

  @@index([recruiterUserId])
  @@index([studentProfileId])
}

model SearchQuery {
  id           String   @id @default(uuid())
  studentId    String
  query        String
  filters      Json?
  resultsCount Int?
  searchedAt   DateTime @default(now())

  student User @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([searchedAt])
}

model RecommendationScore {
  id            String   @id @default(uuid())
  studentId     String
  offerId       String

  contentScore  Float
  semanticScore Float    @default(0)
  cfScore       Float    @default(0)
  finalScore    Float

  breakdown    Json?
  modelVersion String   @default("v0")
  computedAt   DateTime @default(now())

  student User  @relation(fields: [studentId], references: [id])
  offer   Offer @relation(fields: [offerId], references: [id])

  @@unique([studentId, offerId])
  @@index([studentId, finalScore(sort: Desc)])
  @@index([offerId, finalScore(sort: Desc)])
  @@index([computedAt])
}

// ─────────────────────────────────────────
// ONBOARD PUBLIC SESSION DATA (continued)
// ─────────────────────────────────────────

model PublicInterview {
  id                    String   @id @default(uuid())
  sessionKey            String
  status                String   @default("IN_PROGRESS")
  personaKey            String
  interviewerName       String
  interviewerRole       String
  interviewStyle        String
  difficultyLevel       String
  company               String?
  jobTitle              String?
  jobDescription        String?  @db.Text
  recruiterMode         String   @default("TECHNICAL")
  totalExchanges        Int      @default(0)
  overallScore          Int      @default(0)
  technicalCompetency   Int      @default(0)
  communicationSkills   Int      @default(0)
  problemSolving        Int      @default(0)
  culturalFit           Int      @default(0)
  acceptanceProbability Int      @default(0)
  keyStrengths          String[]
  areasForImprovement   String[]
  recommendations       String[]
  nextSteps             String[]
  summary               String   @default("")
  transcript            Json?
  data                  Json?
  pdfUrl                String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([sessionKey])
  @@index([createdAt])
}
