# Same NeonDB the backend uses (backend DB_URL). Prefer the DIRECT (non-pooler) URL;
# a pooled URL works too since DB_STATEMENT_CACHE_SIZE=0.
DATABASE_URL=

# Must match the backend's ML_INTERNAL_TOKEN.
ML_INTERNAL_TOKEN=dev-token

# Inside docker-compose this is the qdrant service name; use localhost if running natively.
QDRANT_HOST=qdrant
QDRANT_PORT=6333

BGE_MODEL=BAAI/bge-m3
MODEL_VERSION=bge-m3-v1
SYNC_INTERVAL_MINUTES=5
LOG_LEVEL=INFO

# ── M7 pipeline mode (single master toggle) ─────────────────────────────────
#   false → current pushed behavior (M6): Nest's top-K content candidates, semantic scored
#           for those only, Nest blends 0.6*content + 0.4*semantic.
#   true  → M7: multi-source retrieval (content + semantic ANN + CF + popularity) → RRF →
#           3-signal blend → MMR + slate; sidecar returns the fused finalMlScore.
# Flip + recompute to compare techniques visually. CF needs no switch: it's 0 until a model is
# trained, then the cf ramp weights it in by interaction count.
RECO_PIPELINE_ADVANCED=false
